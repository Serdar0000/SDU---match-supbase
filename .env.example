# Supabase Configuration
# Получить на: https://supabase.com/dashboard/project/YOUR_PROJECT/settings/api
SUPABASE_URL=https://your_project_id.supabase.co
SUPABASE_ANON_KEY=your_supabase_anon_key_here

# Cloudinary Configuration
# Получить на: https://console.cloudinary.com
CLOUDINARY_CLOUD_NAME=your_cloud_name_here
CLOUDINARY_UPLOAD_PRESET=your_unsigned_preset_here
CLOUDINARY_API_KEY=your_api_key_here

# Resend (Email Notifications)
# Получить на: https://resend.com/api-keys
RESEND_API_KEY=re_your_resend_api_key_here
